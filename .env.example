# =====================================================================
# Event-Driven GitHub Automation Bot - environment variables (EXAMPLE)
# Copy to apps/api/.env and apps/web/.env.local and fill in real values.
# NEVER commit real secrets. This file ships placeholders only.
# =====================================================================

# --------------------------- API (apps/api) ---------------------------
PORT=4000

# Neon Postgres connection string (free, no card)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# Upstash Redis connection string for BullMQ (free, no card)
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# Session JWT (generate a long random string, e.g. `openssl rand -hex 32`)
JWT_SECRET=replace-with-long-random-string
SESSION_COOKIE_NAME=gha_session

# Public origins (local dev shown; set to deployed URLs in production)
WEB_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:4000

# GitHub App (ONE app provides user OAuth sign-in + installation tokens)
GITHUB_APP_ID=000000
GITHUB_APP_SLUG=your-app-slug
GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_APP_CLIENT_SECRET=replace-me
# base64 of the App private key PEM: `base64 -w0 private-key.pem`
GITHUB_APP_PRIVATE_KEY_BASE64=base64-encoded-pem-goes-here
GITHUB_WEBHOOK_SECRET=replace-with-long-random-string

# Slack Incoming Webhook URL (free workspace + app, no card)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Groq (free tier, no card) - AI triage
GROQ_API_KEY=replace-me
GROQ_MODEL=llama-3.3-70b-versatile

# --------------------------- Web (apps/web) ---------------------------
# Base URL of the API the browser calls (non-secret, exposed to client)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
